<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
   <children>
      <Label layoutX="267.0" layoutY="60.0" text="Log in">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <TextField fx:id="usernameLogin" layoutX="158.0" layoutY="140.0" prefHeight="25.0" prefWidth="283.0" />
      <Label layoutX="90.0" layoutY="144.0" text="Username:" />
      <Label layoutX="94.0" layoutY="184.0" text="Password:" />
      <Button layoutX="275.0" layoutY="224.0" mnemonicParsing="false" onAction="#handleLogin" text="Log in" />
      <Button layoutX="493.0" layoutY="328.0" mnemonicParsing="false" onAction="#switchToSignup" text="Sign up" />
      <Label layoutX="246.0" layoutY="332.0" text="Don't have an account yet? Sign up here ---&gt;" />
      <PasswordField fx:id="passwordLogin" layoutX="158.0" layoutY="180.0" prefHeight="25.0" prefWidth="283.0" />
   </children>
</AnchorPane>
