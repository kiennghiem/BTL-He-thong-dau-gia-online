<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" spacing="25.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionDetailController">
    <children>
        <Label fx:id="lblTitle" text="Auction Details">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>
        
        <VBox spacing="15.0" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 20; -fx-background-color: #fcfcfc; -fx-background-radius: 5; -fx-border-radius: 5;">
            <children>
                <GridPane hgap="15.0" vgap="15.0">
                    <children>
                        <Label text="Description:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="lblDescription" text="N/A" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Current Price:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="lblPrice" text="0.00" style="-fx-text-fill: #c0392b; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Status:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="lblStatus" text="OPEN" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="End Time:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Label fx:id="lblEndTime" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="btnApprove" mnemonicParsing="false" onAction="#handleApproveAuction" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Approve Auction" visible="false" managed="false" />
                <Button fx:id="btnEndEarly" mnemonicParsing="false" onAction="#handleEndEarly" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="End Auction Early" visible="false" managed="false" />
                <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancelAuction" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancel Auction" visible="false" managed="false" />
                <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="35.0" prefWidth="100.0" style="-fx-cursor: hand;" text="Back" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
</VBox>
