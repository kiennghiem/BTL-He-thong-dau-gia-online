<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionDetailController">
    <children>
        <Label fx:id="lblTitle" text="Auction Title">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <GridPane hgap="10.0" vgap="10.0">
            <children>
                <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label fx:id="lblDescription" text="Description here" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                
                <Label text="Current Price:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label fx:id="lblPrice" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                
                <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label fx:id="lblStatus" text="OPEN" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                
                <Label text="End Time:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Label fx:id="lblEndTime" text="Time here" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancelAuction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Cancel Auction" visible="false" />
                <Button mnemonicParsing="false" onAction="#handleBack" text="Back" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
