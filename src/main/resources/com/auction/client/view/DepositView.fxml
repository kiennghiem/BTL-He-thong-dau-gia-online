<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.DepositController">
   <children>
      <Label text="Wallet Funding">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label text="Add virtual funds to your account for bidding." textFill="#7f8c8d">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
      
      <VBox spacing="10.0" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 20; -fx-background-color: #f9f9f9; -fx-background-radius: 8; -fx-border-radius: 8;">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Account Name (Auto-filled)" />
                  <TextField fx:id="tfUsername" editable="false" prefHeight="35.0" style="-fx-background-color: #ecf0f1;" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Amount to Deposit ($)" />
                  <TextField fx:id="tfAmount" prefHeight="35.0" promptText="Enter amount (e.g. 5000)" />
               </children>
            </VBox>
         </children>
         <VBox.margin>
            <Insets left="50.0" right="50.0" />
         </VBox.margin>
      </VBox>
      
      <VBox alignment="CENTER" spacing="15.0">
         <children>
            <Button fx:id="btnConfirm" onAction="#handleConfirmDeposit" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Confirm Deposit" />
            <Button onAction="#handleCancel" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="Back" />
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
